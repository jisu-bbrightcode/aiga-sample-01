# ─────────────────────────────────────────────────────────────
# PB-INFRA-001 — DUMMY-STATE local development env reference
# ─────────────────────────────────────────────────────────────
# Operator decision (BBR-499, 2026-06-29): Neon/Vercel credentials are NOT
# ready yet → proceed development in a DUMMY/placeholder state. Real
# provisioning (real DATABASE_URL, Vercel projects, deploy gate) is tracked
# separately and must replace these values before any real deploy.
#
# Usage:
#   cp .env.dummy.reference .env.local
#   # backend (apps/server) also needs a reachable Postgres — see DATABASE_URL.
#
# NONE of these are real secrets. Do not deploy with them. Frontend SPAs
# (apps/app, apps/admin) run fully on these dummy values; the NestJS server
# (apps/server) additionally needs a Postgres reachable at DATABASE_URL.

# ===== Core / Database (Neon in prod; LOCAL/dummy here) =====
# Dummy state: point at a LOCAL Postgres. Either run one locally
#   (e.g. `docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16`)
# or, when ready, swap in a real Neon dev-branch pooled URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiga_dev?sslmode=disable

# ===== Auth (better-auth) — DUMMY secret, local URLs =====
# Replace with `openssl rand -base64 32` before any shared/deployed env.
BETTER_AUTH_SECRET=dummy_local_dev_secret_change_me_00000000000000
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ===== Server =====
PORT=3002
APP_URL=http://localhost:3000
EMAIL_PROVIDER=resend
EMAIL_FROM=AIGA Dev <noreply@example.com>

# ===== Client (Vite app/admin) =====
VITE_API_URL=http://localhost:3002
VITE_APP_NAME=AIGA (dev)

# ===== Optional providers — LEFT BLANK on purpose =====
# All of the below are feature-gated: absence disables only that feature,
# the server still boots. Wire real values via the separate porting workflow
# (see doc/plans/PB-INFRA-001-neon-vercel-environment.md §4).
RESEND_API_KEY=
BLOB_READ_WRITE_TOKEN=
OPENAI_API_KEY=
GEMINI_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
KCB_ADAPTER_BASE_URL=

# ===== Neon/Vercel automation tokens — NOT set in dummy state =====
# Provided later via secure runner creds; needed only for preview-branch
# automation (scripts/neon-branch.mjs) and the deploy-gate verifier.
NEON_API_KEY=
NEON_PROJECT_ID=
VERCEL_TOKEN=
