# Demo deploy — per-project env key reference (VALUES omitted).
#
# This lists exactly which keys each Vercel project needs for the demo.
# Full descriptions live in .env.example. Set values via:
#   cd <project dir> && vercel env add <KEY> production
# Cross-ref URLs (=app/admin/api URL) are known only after Pass A deploy.

# ─────────────────────────────────────────────────────────────
# Local driver (.env.local at repo root — NOT committed)
# ─────────────────────────────────────────────────────────────
NEON_API_KEY=            # Neon API token (provision + branch scripts)
NEON_PROJECT_ID=         # filled after `neonctl projects create`
VERCEL_TOKEN=            # or run `vercel login` once
DATABASE_URL=            # direct(non-pooler) for migrate, then pooled for runtime
PRODUCT_BUILDER_SEED_EMAIL=demo@product-builder.test
PRODUCT_BUILDER_SEED_PASSWORD=   # openssl rand -base64 18

# ─────────────────────────────────────────────────────────────
# product-builder-api  (Root Dir: apps/server — serverless)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=            # Neon POOLED (-pooler) url
BETTER_AUTH_SECRET=      # openssl rand -base64 32
BETTER_AUTH_URL=         # = api production URL
APP_URL=                 # = app production URL
CORS_ORIGINS=            # = app URL,admin URL (comma-sep)
EMAIL_PROVIDER=resend
RESEND_API_KEY=          # optional but recommended (magic link / verify)
EMAIL_FROM=              # e.g. "Flotter <noreply@flotter.io>"
BLOB_READ_WRITE_TOKEN=   # optional (image upload)
# AI keys optional — server boots without them
# OPENAI_API_KEY= / GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# product-builder-app  (Root Dir: repo root — Vite SPA)
# ─────────────────────────────────────────────────────────────
VITE_API_URL=            # = api production URL (BUILD-TIME)

# ─────────────────────────────────────────────────────────────
# product-builder-admin  (Root Dir: apps/admin — Vite SPA)
# ─────────────────────────────────────────────────────────────
VITE_API_URL=            # = api production URL (BUILD-TIME)

# ─────────────────────────────────────────────────────────────
# product-builder-ai-runtime  (Root Dir: apps/ai-runtime — Next.js)
# ─────────────────────────────────────────────────────────────
DOMAIN_SERVER_URL=       # = api production URL
ALLOWED_ORIGINS=         # = app URL,admin URL (comma-sep)
AI_MOCK=1                # demo without real AI credits; unset to use real gateway
# AI_GATEWAY_MODEL= / AI_GATEWAY_FALLBACK_MODELS=  (when AI_MOCK unset)
