# Database (Neon)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/atlas?sslmode=require"

# Project
APP_NAME=Flotter
VITE_APP_NAME=Flotter

# Server
PORT=3002
APP_URL=https://atlas.com

# better-auth
BETTER_AUTH_SECRET=your_better_auth_secret_key
# 로컬: Vite dev 서버(3000)가 /api/auth/* 를 :3002 로 프록시. baseURL 은 3000 으로 맞춤.
BETTER_AUTH_URL=http://localhost:3000
# Production: BETTER_AUTH_URL=https://app.flotter.io  (Vercel 등에서 /api/auth 가 서버 핸들러로 라우팅됨)
# Cross-subdomain cookie sharing 필요 시: BETTER_AUTH_COOKIE_DOMAIN=.flotter.io

# CORS — 허용할 origin (콤마 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Production: CORS_ORIGINS=https://app.flotter.io,https://flotter.io

# ─── OAuth Callback URLs (provider 콘솔에 등록할 값) ──────────────
# 아키텍처: app 과 auth API 가 같은 origin (별도 api.* 서브도메인 없음)
# Built-in (socialProviders): {origin}/api/auth/callback/{provider}
#   Google    — http://localhost:3000/api/auth/callback/google
#               https://dev-app.flotter.io/api/auth/callback/google
#               https://app.flotter.io/api/auth/callback/google
#   LinkedIn  — 같은 패턴, provider=linkedin
# Generic OAuth (plugins): {origin}/api/auth/oauth2/callback/{providerId}
#   Kakao     — http://localhost:3000/api/auth/oauth2/callback/kakao
#               https://app.flotter.io/api/auth/oauth2/callback/kakao
#   Naver     — 같은 패턴, providerId=naver

# Client API
VITE_API_URL=http://localhost:3002

# KG INICIS reusable payment provider
PAYMENT_INICIS_MODE=test
PAYMENT_INICIS_MID=your_inicis_mid
PAYMENT_INICIS_SIGN_KEY=your_inicis_sign_key
PAYMENT_INICIS_INI_API_KEY=your_inicis_ini_api_key
PAYMENT_INICIS_CLIENT_IP=127.0.0.1
PAYMENT_INICIS_NOTI_ALLOWED_IPS=inicis_noti_ip_1,inicis_noti_ip_2
PAYMENT_INICIS_TRUST_PROXY=false
# PAYMENT_INICIS_NOTI_URL=https://your-app.example.com/api/webhooks/inicis/noti
# PAYMENT_INICIS_CLOSE_URL=https://your-app.example.com/payment/inicis/close

# Rate Limiting (ThrottlerGuard)
# RATE_LIMIT_ENABLED=true

# Community — 등급별 게시글 열람 일일 제한 (BBR-1133)
# 비회원/일반 회원은 하루 N회로 제한, 인증회원(아래 role 집합)은 무제한.
# RATE_LIMIT_ENABLED=false 로 두면 전체 비활성화됩니다.
# COMMUNITY_POST_VIEW_GUEST_DAILY_LIMIT=5
# COMMUNITY_POST_VIEW_GENERAL_DAILY_LIMIT=20
# COMMUNITY_POST_VIEW_VERIFIED_ROLES=admin,moderator,verified,verified_member,system
# COMMUNITY_POST_VIEW_AUTHENTICATED_UNLIMITED=false

# Google OAuth (https://console.cloud.google.com/ → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LinkedIn OAuth (https://www.linkedin.com/developers/apps → Auth)
# Product 에 "Sign In with LinkedIn using OpenID Connect" 추가 필수
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Apple OAuth (https://developer.apple.com/ → Certificates, Identifiers & Profiles)
APPLE_CLIENT_ID=your_apple_service_id
APPLE_CLIENT_SECRET=your_apple_client_secret

# Kakao OAuth (https://developers.kakao.com/ → 앱 키)
# Configured via better-auth genericOAuth plugin — callback: /api/auth/oauth2/callback/kakao
# CLIENT_ID = REST API 키, CLIENT_SECRET = 보안 메뉴의 Client Secret
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Naver OAuth (https://developers.naver.com/ → 애플리케이션)
# Configured via better-auth genericOAuth plugin — callback: /api/auth/oauth2/callback/naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ─── Backup: Google Drive ──────────────────────────────
# OAuth credentials from Google Cloud Console → APIs & Services → Credentials.
# These are independent of the social-login GOOGLE_CLIENT_ID/SECRET above:
# the backup feature uses its own OAuth client because it requests Drive
# scopes (drive.file) that the login client should not hold.
# These are app OAuth credentials only. Do not put an operator's Google Drive
# access/refresh token or service-account credential in env. Each logged-in
# user connects their own Drive account through the OAuth popup.
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3002/api/backup-googledrive/oauth/callback

# Comma-separated app origins allowed to receive the OAuth popup completion
# postMessage. Required when app and API run on different origins.
BACKUP_GOOGLEDRIVE_CALLBACK_ORIGINS=http://localhost:3000

# HMAC secret for OAuth state token (≥32 chars random). Generate with:
#   openssl rand -base64 32
BACKUP_GOOGLEDRIVE_OAUTH_STATE_SECRET=your_state_secret_min_32_chars

# AES-256-GCM cipher keys (32-byte, base64). Rotate by incrementing _VERSION
# and adding a new _V<N> entry; old keys MUST stay set so historical
# credentials remain decryptable. Generate each with:
#   openssl rand -base64 32
BACKUP_GOOGLEDRIVE_TOKEN_KEY_VERSION=1
BACKUP_GOOGLEDRIVE_TOKEN_KEY_V1=your_base64_32byte_aes_key

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key
# Resend webhook signing secret (whsec_...) from the Resend dashboard webhook
# endpoint config. Required to accept delivery/bounce/complaint events at
# POST /api/webhooks/resend. Leave empty to disable the webhook (returns 503).
RESEND_WEBHOOK_SECRET=
EMAIL_FROM="Superbuilder <noreply@superbuilder.app>"

# SOLAPI message sending (optional admin feature)
# Product Builder templates must stay disabled after cloning. Set true only
# after replacing every placeholder credential with real project/provider values.
SOLAPI_ENABLED=false
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_DEFAULT_SENDER=0212345678
SOLAPI_WEBHOOK_SECRET=your_solapi_webhook_secret
SOLAPI_API_BASE_URL=https://api.solapi.com

# PostHog Analytics
POSTHOG_API_KEY=phc_your_posthog_api_key
POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_API_KEY=phc_your_posthog_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Featurebase product feedback dual-write
# Server-only. Creates in-review author-only Featurebase posts from the in-app feedback form.
FEATUREBASE_API_KEY=fb_your_featurebase_api_key
FEATUREBASE_FEEDBACK_BOARD_ID=your_featurebase_feedback_board_id
FEATUREBASE_API_URL=https://do.featurebase.app
FEATUREBASE_API_VERSION=2026-01-01.nova
# Optional comma-separated tags appended to flotter-app-feedback and the feedback type.
FEATUREBASE_FEEDBACK_TAGS=posthog-survey
# Optional: public | authorOnly | companyOnly. Defaults to authorOnly.
FEATUREBASE_FEEDBACK_VISIBILITY=authorOnly

# FENM serving integration (optional)
# Server boot does not require this service to be reachable; calls fail at request time if unset/unavailable.
FENM_SERVICE_URL=http://localhost:8788

# ─── ElectricSQL (Local-First Sync) ────────────────────────
# 서버: Electric Cloud 프록시에 사용. 클라이언트에는 secret/source_id 를 노출하지 않는다.
ELECTRIC_SECRET=your_electric_api_token
ELECTRIC_SOURCE_ID=your_electric_source_id
ELECTRIC_URL=https://api.electric-sql.cloud
# 기본값: true. 로컬 진단에서만 false 로 내려서 인증/프로젝트 검사를 우회한다.
# ELECTRIC_PROXY_AUTH_REQUIRED=false
# Electron: 서버 프록시를 통한 read sync. 직접 Electric URL override 는 진단 전용.
FLOTTER_API_URL=http://localhost:3002
# FLOTTER_ELECTRON_ELECTRIC_URL=http://localhost:3002/api/electric
# Live smoke only: allows real story_worlds create -> Electric echo -> cleanup delete.
# FLOTTER_ELECTRON_LIVE_ALLOW_SERVER_MUTATION=1
# Browser: default cloud-first. Set VITE_BROWSER_CACHE=sqlite-wasm for the
# SQLite/WASM light workspace cache. Browser PGlite is removed.
VITE_BROWSER_CACHE=
# Deprecated compatibility flag. Ignored by the web runtime.
VITE_LOCAL_FIRST=false

# Vercel AI Gateway
AI_GATEWAY_URL=https://gateway.ai.vercel.com/v1
AI_GATEWAY_API_KEY=your_ai_gateway_key

# Logging
LOG_LEVEL=info

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# Cloudflare Stream video lecture provider (optional until video-lecture actions run)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

# shadcn studio (optional)
EMAIL=
LICENSE_KEY=

# Vercel KV
KV_REST_API_URL=https://your-kv.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token_here

# Landing (B2B2C)
NEXT_PUBLIC_API_URL=http://localhost:3002
INTERNAL_API_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3010
