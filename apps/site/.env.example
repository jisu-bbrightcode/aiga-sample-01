# Public API base (NestJS server). Inlined at build by Next (NEXT_PUBLIC_*).
NEXT_PUBLIC_API_URL=https://product-builder-api.vercel.app

# Canonical public origin for SEO (canonical URLs, Open Graph, sitemap, robots).
# No trailing slash. Falls back to siteConfig.seo.url when unset.
NEXT_PUBLIC_SITE_URL=https://aiga.kr
