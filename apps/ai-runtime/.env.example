# AI Runtime Server 환경 변수

# Google AI API Key (Gemini) — fallback 모델용. 항상 필요.
GOOGLE_GENERATIVE_AI_API_KEY=your-key-here

# Anthropic API Key — snapshot.modelProvider="anthropic" 캐릭터 호출 시 필요
ANTHROPIC_API_KEY=

# OpenAI API Key — snapshot.modelProvider="openai" 캐릭터 호출 시 필요
OPENAI_API_KEY=

# Domain Server URL (tRPC saveAssistant 호출용)
DOMAIN_SERVER_URL=http://localhost:3002

# CORS 허용 Origin (프론트엔드 URL, 콤마로 구분)
ALLOWED_ORIGINS=http://localhost:3000

# 개발 전용: 실제 AI 호출 대신 mock streaming 사용
# E2E 테스트에서 사용
AI_MOCK=false
