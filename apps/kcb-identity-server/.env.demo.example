# Copy to .env and fill in. Used by docker-compose.demo.yml (kcb-java service).
# Java bridge talks to the KCB operations gateway directly, so the host running
# it must have outbound access to https://safe.ok-name.co.kr.

KCB_MODE=PROD
KCB_SITE_CODE=V72010000000
KCB_SITE_NAME=코리아메디케어
# Public origin the user's browser + KCB can reach. For local demo this is the
# web app origin; the popup return path is proxied to the Nest server.
KCB_SITE_URL=http://localhost:3000
KCB_STANDARD_RETURN_URL=http://localhost:3000/api/identity-verifications/kcb/popup-return
KCB_POPUP_URL=https://safe.ok-name.co.kr/CommonSvl
# Shared secret between the Nest server and this Java bridge.
KCB_INTERNAL_AUTH_TOKEN=change-me-internal-token
KCB_OFFICIAL_SOURCE_MAP=Korea Medicare KCB package 2026-06-17
