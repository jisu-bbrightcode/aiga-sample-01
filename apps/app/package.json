{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "build": "pnpm run test:auth && pnpm run check:vite-shared-runtime && cross-env VITE_API_URL=${VITE_API_URL:-http://localhost:3002} vite build",
    "preview": "vite preview",
    "lint": "node ../../scripts/biome-changed.mjs lint .",
    "test": "cross-env NODE_ENV=test vitest",
    "test:auth": "cross-env NODE_ENV=test vitest run src/pages/auth-signup-flow.test.tsx src/layouts/dashboard-layout.test.tsx",
    "check-types": "tsc --noEmit",
    "check:vite-shared-runtime": "tsx scripts/assert-vite-shared-runtime-dedupe.ts",
    "e2e": "playwright test",
    "e2e:browser-cache-reentry": "playwright test e2e/browser-cache-reentry.spec.ts --config playwright.config.ts --project chromium"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@repo/api-client": "workspace:^",
    "@repo/core": "workspace:^",
    "@repo/data": "workspace:^",
    "@repo/drizzle": "workspace:^",
    "@repo/features": "workspace:^",
    "@repo/shared": "workspace:^",
    "@repo/ui": "workspace:^",
    "@repo/widgets": "workspace:^",
    "@hookform/resolvers": "^5.2.2",
    "@lottiefiles/dotlottie-react": "0.19.1",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-router": "^1.122.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "conf": "^15.1.0",
    "date-fns": "^4.1.0",
    "glin-profanity": "^3.3.0",
    "jotai": "^2.12.3",
    "lucide-react": "^0.511.0",
    "motion": "^12.29.2",
    "posthog-js": "^1.351.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/router-devtools": "^1.122.1",
    "@tanstack/router-plugin": "^1.122.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.5",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cross-env": "^7.0.3",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.5"
  }
}
