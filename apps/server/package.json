    "@nestjs/platform-fastify": "^11.1.11",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@react-email/components": "^1.0.6",
    "@react-email/render": "^2.0.4",
    "@repo/core": "workspace:^",
    "@repo/drizzle": "workspace:^",
    "@repo/features": "workspace:^",
    "@repo/shared": "workspace:^",
    "@vercel/blob": "^1.1.1",
    "ai": "^4.3.19",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.7.1",
    "inngest": "^3.54.0",
    "postgres": "^3.4.8",
    "react": "^19.2.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/supertest": "^6.0.2",
    "@vercel/node": "^5.6.11",
    "jest": "^30.0.0",
    "pg": "^8.17.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
